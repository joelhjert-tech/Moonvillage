      "LogName": "Annette Bundle Notification Action",
      "Action": "EditData",
      "Target": "Data/TriggerActions",
      "Entries": {
        "AnnetteHouse_BundleComplete": {
          "Id": "AnnetteHouse_BundleComplete",
          "Trigger": "LocationChanged",
          "Actions": [
            "spacechase0.SpaceCore_ShowHudMessage \"You've dropped off all the materials! Annette needs some time to build. Come back tomorrow!\"",
