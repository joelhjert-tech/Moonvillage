{
  /* --- ITEMS: TEAS --- */
  "defensetea.name": "Defense Tea",
  "defensetea.desc": "A robust tea brewed with coconut and tiger's eye. Boosts your defense.",

  "lucktea.name": "Luck Tea",
  "lucktea.desc": "A shimmering tea made from pomegranate and jade. Grants a bit of extra luck.",

  "healingtea.name": "Healing Tea",
  "healingtea.desc": "A soothing floral blend of blackberries and quartz. Great for restoring health.",

  "farmingtea.name": "Farming Tea",
  "farmingtea.desc": "An earthy brew of garlic and spring onions. Improves your farming focus.",

  "miningtea.name": "Mining Tea",
  "miningtea.desc": "A spicy kick of hot pepper and diamond. Helps you swing the pickaxe harder.",

  "fishingtea.name": "Fishing Tea",
  "fishingtea.desc": "A salty blend of seaweed and clam. Makes the fish bite more often.",

  "attacktea.name": "Attack Tea",
  "attacktea.desc": "A powerful infusion of ginger and obsidian. Increases your attack power.",

  "speedtea.name": "Speed Tea",
  "speedtea.desc": "A refreshing mix of carrot and mango. Gives you a burst of energy and speed.",
  
  "event.quest_reward_random_tea": "You received a random magical tea.",

  /* --- MAIL: STORY & RESTORATION --- */
  "message.magic_disturbance": "The air grows heavy and sparks with a strange, unnatural energy...",
  "mail.mysterious_rumor": "To the farmer...^There are whispers in the wind. An ancient magic sleeps in the Secret Woods, waiting for one with the right energy to awaken it. Seek the dormant circle...^ - A Friend",
  "event.secret_woods_anomaly": "A strange shimmer ripples through the air toward the overgrown passage in the north... Something ancient has just awakened.",
  "mail.wizard_invite": "@!^I've sensed a strange disturbance in the magical currents near the Secret Woods. It seems to be linked to an ancient legend of a lost village. Come to my tower as soon as you can; we have much to discuss.^  - Rasmodius",
  "mail.wizard_quest_mail": "Greetings @,^As we discussed, the magical disturbances are fluctuating deep within the Secret Woods. Return to the clearing and investigate further. We must uncover the truth behind this creeping shadow.^  - Rasmodius",
  "mail.wizard_guild_invite": "Greetings @,^My research has led me to an important conclusion regarding the woods. Meet me at the Adventurer's Guild. Annette and Marlon are waiting for us there to discuss how we shall break the curse.^  - Rasmodius",
  "mail.annette_party": "Dear @!^The curse is finally broken and life has returned to Moon Village! We cannot thank you enough for your courage. Come to the village tonight; we're throwing a party to celebrate our hero!^  - Annette",
  "mail.annette_house_ready": "Hello @,^Thank you so much for the materials! The Townhall is finally renovated. You can come visit anytime!^  - Annette",
  "mail.inn_ready": "Hello @,^The Hidden Hearth is looking as good as new! We couldn't have done it without your help. Drop by when you have time!^  - Annette",
  "mail.spirit_healer_ready": "Greetings @,^The materials were perfect. The Spirit Healer's house has been restored to its former glory. Thank you for your kindness.^  - Annette",
  "mail.herbalist_ready": "Hello @,^Celestial Remedies is ready! The herbs are already starting to grow back. Come take a look when you have time.^  - Annette",
  "mail.granary_ready": "Hello @,^The Cosmic Corral is fully repaired and the livestock are once again happy and thriving. Your help means the world to Moonvillage!^ - Annette",
  "mail.grocery_ready": "Hello @,^The Moon Glow Grocery Store is open for business again! Come by and check out the new stock.^  - Annette",
  
  /* --- QUESTS --- */
  "quest.secret_woods_title": "A Path Into the Woods",
  "mail.secret_woods_quest": "To the farmer...^There are whispers in the wind. An ancient magic sleeps in the Secret Woods, waiting to be found. Find a way in and investigate, and you will be rewarded.^ - A Friend",
  "quest.secret_woods_description": "An anonymous letter claims that an ancient power lies dormant within the hidden depths of the forest. Perhaps it's time to investigate what lies beyond the old overgrown paths.",
  "quest.secret_woods_objective": "Find a way into the Secret Woods.",
  "quest.wizard_title": "The Wizard's Request",
  "quest.wizard_description": "The Wizard sensed a magical disturbance and asked me to investigate the Secret Woods further.",
  "quest.wizard_objective": "Return to the Secret Woods and find what could be causing it.",
  
  /* --- WIZARD EVENTS (Viktiga!) --- */
  "event.wizard_tower_1": "Ah, @... right on time. The arcane ley-lines have been thrashing wildly, and their apex points directly toward the Secret Woods.",
  "event.wizard_tower_2": "An ancient anomaly is bleeding into our reality. Legends speak of a settlement long forgotten, swallowed by shadows centuries ago. You must go there, adept, and peer into the dark.",
  "event.wizard_tower_3": "Do you feel it, farmer? The very fabric of magic is warped and distorted in this clearing.",

  /* --- STAGE 4: ANNETTE INTRO --- */
  "event.annette_intro_1": "A stranger...? Stay back! Wait... you don't look like one of Leander's shadows...",
  "event.annette_intro_2": "Forgive me, my mind is still hazy. I am Annette, Prefect of Moon Village... or what remains of it. Who might you be?",
  "event.annette_intro_3": "@... A farmer? Incredible. By forcing your way into these woods, you have shattered a barrier we thought was absolute. I cannot fully express the weight of what you've done.",
  "event.annette_intro_4": "Tell me, @... is there someone else in this valley who commands the arcane? A witch, or perhaps a wizard?",
  "event.annette_intro_5": "Then there is no time to lose. I must seek out this wizard immediately. Stay safe, farmer, but know that you have given my people a flicker of hope. We shall meet again, I promise!",

  /* --- STAGE 6: THE GUILD MEETING --- */
  "event.guild_meeting.wizard_1": "Thank you for coming, @. We have much to discuss regarding the curse on Moon Village.",
  "event.guild_meeting.marlon_1": "I've seen many things in these mines, but a village frozen in time... that's dark magic of the highest order.",
  "event.guild_meeting.wizard_2": "@, Annette is the leader of Moon Village, a place I know only from legends.",
  "event.guild_meeting.marlon_2": "Same here, just old stories shared on cold nights by a fire.",
  "event.guild_meeting.annette_1": "I assure you my home is real and so is the curse. But I can’t break it by myself.",
  
  "event.guild_meeting.q1": "A curse?!?!",
  "event.guild_meeting.q2": "Why can’t you break it yourself?",
  
  "event.guild_meeting.marlon_3": "The short version is that a power mad wizard cast a curse that was supposed to freeze the village in time forever. But Annette here was able to cast a spell that put in a loophole.",
  "event.guild_meeting.annette_2": "It happened so fast. One moment we were preparing for the festival, the next... everything went cold and grey. I was lucky I heard Leander casting his curse. I barely had time to chant the counter or else we never would have had a chance to be saved.",
  "event.guild_meeting.marlon_4": "Once you used cold iron to break the seal on the woods, you became that loophole.",
  "event.guild_meeting.wizard_3": "By breaking the seal, you have tied yourself to the village’s fate. You are the only person capable of breaking the curse. The magic has made so that only Annette having cast the counter and yourself as the key leave or enter the village.",
  "event.guild_meeting.wizard_4": "The source of the curse is deep within the Celestial Forest. We need the farmer's help to restore the village's heart.",
  "event.guild_meeting.annette_3": "Please, @. Meet me in Moon Village when you're ready. Go through the woods where you first met me. I'll show you what remains of my home.",
  "event.guild_meeting.wizard_5": "@, once Annette and I have more time to speak, I will send you a more detailed explanation of what happened to Moon Village.",
  
  "event.moonvillage_arrival.annette_1": "Welcome to Moon Village, @. Or... what is left of it.",
  "event.moonvillage_arrival.annette_2": "The people you see... they aren't moving. The curse has frozen them in time. We need to restore the village's magic to wake them.",
  "event.moonvillage_arrival.annette_3": "The old Townhall is the center of our magic. I will wait for you there. Please, @... bring the light back to my home.",

/* --- NEW QUEST: THE ARCANE KEY --- */
  "quest.arcane_key_title": "The Arcane Key",
  "quest.arcane_key_description": "The Wizard needs rare materials to stabilize the portal to Moon Village.",
  "quest.arcane_key_objective": "Deliver the items to Rasmodius: 1 Void Essence, 1 Magma Cap, 5 Quartz.",
  "quest.arcane_key_complete": "The portal to Moon Village is now active!",
  
  /* --- BUNDLES --- */
  "bundle.townhall.name": "Moon Village Restoration",
  "bundle.townhall.description": "The heart of the village is frozen. Bring these offerings of light and nature to begin the restoration.",
  "bundle.townhall.completed": "The magic returns to the townhall... Grandmother Blackthorne's house has been restored!",
  
  "bundle.annette_house.name": "Renovate Annette's Townhall House",
  "bundle.annette_house.desc": "Help Annette fix her home to gain access.",
  "bundle.spirit_healer.name": "Spirit Healer's House Repairs",
  "bundle.spirit_healer.desc": "Restore the Spirit Healer's home.",
  "bundle.moon_grocery.name": "Moon Glow Grocery Repairs",
  "bundle.moon_grocery.desc": "Help repair the Moon Glow Grocery Store.",
  "bundle.herbalist.name": "Celestial Remedies Repairs",
  "bundle.herbalist.desc": "Help rebuild Celestial Remedies.",
  "bundle.moon_inn.name": "Hidden Hearth Repairs",
  "bundle.moon_inn.desc": "Help renovate the old Hidden Hearth.",
  "bundle.moon_granary.name": "Cosmic Corral Repairs",
  "bundle.moon_granary.desc": "Provide materials to fix the Cosmic Corral.",
  
  /* --- STAGE 8: LORILAI WAKES UP --- */
  "event.townhall_fixed.annette_1": "@, you did it! The arcane energy is flowing back into the Townhall. Look... the ice is melting!",
  "event.townhall_fixed.lorilai_1": "W-what happened? It felt like I just blinked, but everything is so... overgrown and cold. Annette? Who is this stranger?",
  "event.townhall_fixed.annette_2": "It is a very long story, Lorilai. We were cursed by Leander, but this farmer has brought us our first spark of hope.",
  "event.townhall_fixed.lorilai_2": "Cursed...? I need to check my herbs immediately! Thank you, stranger, whoever you are. We are in your debt.",

  /* --- ANNETTE DIALOGUE --- */
  "annette.dialogue.Introduction": "Hello! You must be @, the new farmer. I'm Annette. If you ever need anything, please ask. Kira and I were just going for a walk. $1",
  "annette.dialogue.Mon": "Mondays are good for a fresh start. Take it one step at a time, and things will feel much lighter. $1",
  "annette.dialogue.Tue": "The sun is shining beautifully today! I hope you're taking care of yourself, @. Work can wait sometimes. $1",
  "annette.dialogue.Wed": "I love walking around town on Wednesdays. Have you been to the lake? Kira loves the breeze there. $1",
  "annette.dialogue.Thu": "Almost the weekend! Moonvillage has quiet days, and I think that's when people need kindness the most. $0",
  "annette.dialogue.Fri": "Fridays feel special. Are you going to the saloon tonight, @? Don't stay out too late if you're tired. $0",
  "annette.dialogue.Sat": "Saturday is my day off. I like to slow down and spend time with my dog, Kira. $1",
  "annette.dialogue.Sun": "Sundays are for resting. A quiet Sunday can heal your spirit more than you realize. $1",
  "annette.dialogue.Mon8": "Happy Monday, @. It is a busy week. I spent the morning listening to Lorilai and Venessa argue about medicine. My head is spinning! $2",
  "annette.dialogue.Wed10": "Kira and I just came back from the lake. Venessa says the lake is 'messy,' and Lorilai says it is 'pure.' I think it is just a nice place for a dog to swim! $1",
  "annette.dialogue.Fri12": "Heading to the saloon? I hope it is quiet. Sometimes the tension between the two elves makes the room feel a bit awkward. $0",
  "annette.dialogue.Tue16": "The sun is strong today. I have a headache from paperwork. I don't know if I should ask Venessa for a spell or Lorilai for tea... they are so competitive! $2",
  "annette.dialogue.Thu18": "It is very quiet today. I actually tried some of Lorilai’s herbal tea this morning. It was very relaxing. Just... please do not tell Venessa! $1",
  "annette.dialogue.Sun21": "Sundays are for resting. Even Kira is tired of the drama in town lately. We are just going to stay home. $1",
  "annette.dialogue.rain": "I hope you have your boots on, @! It's wet today. I like the sound of the rain; it makes the house feel warm. $1",
  "annette.dialogue.GreenRain": "What is all this green fluff?! Please be careful, @. Kira is very scared of it. $3",
  "annette.dialogue.spring_Mon": "Spring is beautiful! Can you smell the flowers? It makes our morning walks so lovely. $1",
  "annette.dialogue.summer_Wed": "It’s so hot today. Drink plenty of water while you work. I have an extra bottle for me and Kira. $0",
  "annette.dialogue.fall_Fri": "The leaves are changing color. Autumn might be my favorite season. $1",
  "annette.dialogue.winter_Sun": "Brrr... it's freezing! Go home and sit by the fire, @. Even Kira prefers the rug over the snow today. $3",
  "annette.dialogue.Saloon": "Ah, it is good to be off work! I love seeing the village together. I just wish the two elves would stop whispering about each other. $0",
  "annette.dialogue.Mountain": "Kira is having so much fun! She almost chased a squirrel into Lorilai’s herb basket. I had to apologize for ten minutes! $1",
  "annette.dialogue.Forest": "It is so peaceful here. Sometimes I come here to hide from my Prefect duties. If you see Venessa or Lorilai, tell them I am 'busy'! $1",
  "annette.dialogue.Town": "Being Prefect is a big job when your two healers won't even sit at the same table! $2",
  "annette.dialogue.Hearts_2": "It’s lovely talking to you, @. I feel like we’re becoming good friends. $1",
  "annette.dialogue.Hearts_4": "You’re one of the kindest people in the valley. It feels safe having you here. $1",
  "annette.dialogue.Hearts_6": "I’m so glad you moved here. You make this place feel like a real home. $1",
  "annette.dialogue.Hearts_8": "You know, @... I really trust you. I feel like I can tell you anything. $3",
  "annette.dialogue.Hearts_10": "Thank you for always being there. You’re my very best friend in the whole valley. $1",
  "annette.dialogue.AcceptGift_Loved": "Oh, I love this! Thank you so much, @! $1",
  "annette.dialogue.AcceptGift_Liked": "A gift for me? That’s so sweet, thank you! $1",
  "annette.dialogue.AcceptGift_Neutral": "Thank you, this is very nice. $1",
  "annette.dialogue.AcceptGift_Disliked": "Erm... thank you, I guess. But this isn't really my thing. $2",
  "annette.dialogue.AcceptGift_Hated": "Why would you give me this? I really don't like it. $5",
  "annette.dialogue.AcceptGift_(O)724": "Maple syrup! Oh, thank you so much, this is fantastic! $1",
  "annette.dialogue.AcceptGift_(O)72": "A Diamond!! It's stunning! Are you sure you can afford to give this away? $4",
  "annette.dialogue.AcceptGift_(O)80": "Quartz? It's beautiful... I'll keep this somewhere safe! $1",
  "annette.dialogue.AcceptGift_(O)233": "Oh! Ice Cream! This was exactly what I needed. $1",
  "annette.dialogue.AcceptGift_(O)152": "Seaweed? Erm... thanks, I guess. I'm not sure what to do with it. $3",
  "annette.dialogue.AcceptGift_(O)167": "Joja Cola? No thank you. It's just sugar and chemicals. $5",
  "annette.dialogue.AcceptGift_(O)StardropTea": "Oh, Stardrop Tea... it's my favorite. You really shouldn't spoil me like this! $1",
  "annette.dialogue.AcceptBirthdayGift_Loved": "You remembered my birthday? That is incredibly kind. Thank you! $1",
  "annette.dialogue.AcceptBirthdayGift_Liked": "A birthday present? That was very thoughtful. Thank you, @. $1",
  "annette.dialogue.FlowerDance_Accept": "Yes, I'd love to dance with you, @! $1",
  "annette.dialogue.FlowerDance_Decline": "That’s very sweet, but I’m afraid I have to say no today. $2",
  "annette.dialogue.Dumped_Girls": "I thought we had something special, @. I guess I was wrong. $2",
  "annette.dialogue.Divorce": "I don't want to talk right now. Please leave me alone. $5",

  /* --- KIRA DIALOGUE --- */
  "kira.dialogue.Introduction": "Woof! *wags tail eagerly* Hi! I'm Kira. Have you seen my human, Annette, anywhere? She's the best person in the whole world!",
  "kira.dialogue.Mon": "Woof! Today I'm following Annette to the mountains. I'll make sure no scary slimes get anywhere near her!",
  "kira.dialogue.Tue": "Did I hear the word... WALK?! *jumps up and down* Annette is so nice to take me out around town.",
  "kira.dialogue.Wed": "The sun is shining and I smell... fish! I hope Annette lets me have a tiny bite if she catches anything!",
  "kira.dialogue.Thu": "Annette is working so hard in the cellar. I'm lying right outside the door to keep watch so she feels safe.",
  "kira.dialogue.Fri": "The forest is full of exciting smells! But I'm staying close to Annette; I don't want her getting lost without me.",
  "kira.dialogue.Sat": "There are so many people in town today. I'm going to sit nicely and be a very good girl for Annette's sake.",
  "kira.dialogue.Sun": "A quiet day... Annette scratched me behind the ears this morning. It was the best moment of my life! *happy panting*",
  "kira.dialogue.Rainy": "Bleh, it's raining outside. But that's okay, as long as I get to lie on the rug by Annette's feet and dry off.",
  "kira.dialogue.GreenRain": "Why is the sky green?! *low whimpering* I'm staying right here by Annette's side. I'll protect you, Mom!",
  "kira.dialogue.AcceptGift_(O)68": "WOOF! A meatball?! You're almost as nice as Annette! Thank you!",
  "kira.dialogue.AcceptGift_Generic": "*happy woof* Thank you so much! I'm gonna show this to Annette later!",
  "kira.dialogue.RejectGift_Generic": "*sniff sniff* ...No thanks, I can't eat that. Don't you have a bone instead?",

  /* --- LORILAI DIALOGUE --- */
  "lorilai.dialogue.Introduction": "Hello! You must be @, the new farmer. I'm Lorilai, the village herbalist. If you ever feel sick or need help with plants, please come see me. I just saw Prefect Annette and her dog, Kira, heading out for a walk. Annette is a dear friend, but she listens to that 'Healer' Venessa too much. $1",
  "lorilai.dialogue.Mon": "Mondays are like new seeds. Just take it one step at a time, and you will grow well. $1",
  "lorilai.dialogue.Tue": "The sun is so bright today! It is good for the herbs. I hope you are taking care of yourself too, @. Work can wait sometimes. $1",
  "lorilai.dialogue.Wed": "I love walking by the lake on Wednesdays to look for moss. Have you been there lately? Annette says Kira loves the cool breeze by the water. $1",
  "lorilai.dialogue.Thu": "The weekend is almost here. Moonvillage is very quiet today. I think these are the days when people need a little extra kindness. $0",
  "lorilai.dialogue.Fri": "Fridays feel special, don't they? Are you going to the saloon tonight, @? If you feel tired, try some herbal tea instead of staying out too late. $0",
  "lorilai.dialogue.Sat": "Saturday is my day off. I like to walk in the woods and enjoy the trees. It is much better than being busy all the time. $1",
  "lorilai.dialogue.Sun": "Sundays are for resting. Just like the soil needs to rest in winter, our spirits need a quiet day to heal. $1",
  "lorilai.dialogue.Mon8": "A new week! The dirt feels warm today. Venessa probably hates that I get my hands dirty, but the best medicine comes from the ground, not a shiny rock. $1",
  "lorilai.dialogue.Wed10": "I found some rare berries by the lake today. Annette’s dog, Kira, tried to eat them! I told Annette they were for medicine. Venessa would probably just try to 'wish' the pain away. $2",
  "lorilai.dialogue.Fri12": "If you go to the saloon, enjoy yourself! But don't listen to Venessa if she tells you to drink her 'magic water.' My ginger tea is much better for your stomach. $1",
  "lorilai.dialogue.Tue16": "The birds are singing so loudly! They know where the best herbs grow. Venessa stays inside with her books too much. She misses the real magic of the forest. $1",
  "lorilai.dialogue.Thu18": "It is a peaceful day. I am making a new cream for sore muscles. I offered some to Annette, but Venessa rolled her eyes at me. She is so stiff! $2",
  "lorilai.dialogue.Sun21": "I am spending my Sunday talking to the trees. They have more personality than some people in this town... especially certain 'doctors' with pointy ears. $1",
  "lorilai.dialogue.rain": "The plants are so happy for this rain! It is a bit wet for a walk, though. I love the sound of the water on my roof while I dry my herbs. $1",
  "lorilai.dialogue.GreenRain": "What is all this green dust in the air? It feels very strange. Please be careful, @. Annette told me Kira is very scared of it. $3",
  "lorilai.dialogue.spring_Mon": "Spring is here! The air smells like sweet flowers. It makes my morning walks in Moonvillage so lovely. $1",
  "lorilai.dialogue.summer_Wed": "It is very hot today. Please drink plenty of water while you work on the farm. I always carry an extra bottle for myself. $0",
  "lorilai.dialogue.fall_Fri": "The leaves are turning red and gold. Autumn is the best time to gather roots and berries. $1",
  "lorilai.dialogue.winter_Sun": "It is so cold! Go home and stay warm by the fire, @. Even Kira is staying inside on her rug today. $3",
  "lorilai.dialogue.Saloon": "The food here is okay, but it needs more fresh herbs. I tried to give the cook some wild parsley, but Venessa told him it looked 'suspicious.' She has no taste! $2",
  "lorilai.dialogue.Mountain": "Do you see that moss by the water? It is perfect for making healing bandages. Venessa thinks magic rocks are better, but nature provides everything we need. $1",
  "lorilai.dialogue.Forest": "This is where I feel most at home. The trees have so much to tell us. I bet Venessa is hiding in her clinic right now, afraid of a little bit of dirt. $1",
  "lorilai.dialogue.ScienceHouse": "I come here to talk to Robin sometimes. She understands the value of good wood. Unlike the 'Doctor,' who only cares about things that sparkle. $2",
  "lorilai.dialogue.Hearts_2": "It is nice to talk to you, @. I think we are becoming good friends. $1",
  "lorilai.dialogue.Hearts_4": "You are a very kind person. Moonvillage feels safer with you here. $1",
  "lorilai.dialogue.Hearts_6": "I am so happy you moved here. Our village felt a bit empty before. You make this place feel like a real home. $1",
  "lorilai.dialogue.Hearts_8": "You know, @... I really trust you. My heart feels at peace when we talk. $3",
  "lorilai.dialogue.Hearts_10": "Thank you for being such a wonderful friend. You are the person I care about most in this whole valley. $1",
  "lorilai.dialogue.AcceptGift_Loved": "Oh, I love this! It is a wonderful gift. Thank you so much, @! $1",
  "lorilai.dialogue.AcceptGift_Liked": "A gift for me? That is so sweet of you. Thank you! $1",
  "lorilai.dialogue.AcceptGift_Neutral": "Thank you. This is very nice of you to give. $1",
  "lorilai.dialogue.AcceptGift_Disliked": "Oh... thank you, I guess. But this is not really something I like. $2",
  "lorilai.dialogue.AcceptGift_Hated": "Why would you give me this? It does not feel right at all. $5",
  "lorilai.dialogue.AcceptGift_(O)724": "Maple syrup! It comes straight from the trees. Thank you, this is amazing! $1",
  "lorilai.dialogue.AcceptGift_(O)72": "A Diamond! It is so bright and beautiful. Are you sure you want to give this to me? $4",
  "lorilai.dialogue.AcceptGift_(O)80": "Quartz? It is a very clean and healing stone. I will keep it in a safe place. $1",
  "lorilai.dialogue.AcceptGift_(O)233": "Oh! Ice Cream! This is a very sweet treat. It is exactly what I needed today. $1",
  "lorilai.dialogue.AcceptGift_(O)152": "Seaweed? I am not sure what to do with this. It smells a bit strange. $3",
  "lorilai.dialogue.AcceptGift_(O)167": "Joja Cola? No thank you. I only like natural things. This is just sugar and chemicals. $5",
  "lorilai.dialogue.AcceptGift_(O)StardropTea": "Stardrop Tea... it is my favorite thing in the world. You are so kind to me. $1",
  "lorilai.dialogue.AcceptBirthdayGift_Loved": "You remembered my birthday? That makes me so happy, @. Thank you! $1",
  "lorilai.dialogue.AcceptBirthdayGift_Liked": "A birthday present? That was very kind of you to think of me. $1",
  "lorilai.dialogue.FlowerDance_Accept": "I would love to dance with you! Let's go. $1",
  "lorilai.dialogue.FlowerDance_Decline": "That is very sweet, but I am too shy to dance today. I'm sorry. $2",
  "lorilai.dialogue.Dumped_Girls": "I thought we had something special. I feel very sad that I was wrong. $2",
  "lorilai.dialogue.Divorce": "I do not want to talk right now. Please leave me alone with my plants. $5",

  /* --- VENESSA DIALOGUE --- */
  "venessa.dialogue.Introduction": "Greetings. You must be @, the new farmer. I am Venessa, the village Healer. My elven magic can mend any wound. I just saw Annette and her dog, Kira, walking by. Annette is a good leader, but she listens to that herbalist Lorilai way too much. $1",
  "venessa.dialogue.Mon": "Mondays are for new growth. Take it slow, @. Even the oldest trees started as small seeds. $1",
  "venessa.dialogue.Tue": "The sun is very bright. It helps my healing crystals glow. Please do not work too hard; your body needs rest just like the soil. $1",
  "venessa.dialogue.Wed": "I saw Annette and Kira by the lake today. Kira was splashing around, making a mess. It is hard to find quiet spots for meditation lately. $2",
  "venessa.dialogue.Thu": "The village is quiet. On days like this, I focus on my magic. Lorilai thinks her weeds can cure people, but true healing requires more skill. $2",
  "venessa.dialogue.Fri": "It is Friday. Are you going to the saloon tonight, @? If you get a headache, come to me. Do not let Lorilai give you one of her strange 'root drinks.' $1",
  "venessa.dialogue.Sat": "Saturday is my time to connect with the forest. The trees have lived much longer than anyone in Moonvillage. They have many secrets. $1",
  "venessa.dialogue.Sun": "Sunday is for peace. Let your spirit heal today. Even the stars rest during the day, and so should you. $1",
  "venessa.dialogue.Mon8": "It is the second week of the season. I hope you are staying healthy, @. I had to fix a mess Lorilai made yesterday. She tried to heal a scratch with moss! Magic is much cleaner. $2",
  "venessa.dialogue.Wed10": "I saw Annette and Kira by the river. Annette looks stressed. She spends too much time listening to the herbalist's 'natural advice.' She needs real healing. $0",
  "venessa.dialogue.Fri12": "Are you going to the saloon tonight? If you see Lorilai, tell her that my crystals are glowing brighter than her flowers today. She will know what it means. $2",
  "venessa.dialogue.Tue16": "The moon is in a good position for my spells today. My magic feels very strong. Lorilai probably doesn't even feel the moon's power. She is too busy looking at the dirt. $1",
  "venessa.dialogue.Thu18": "Moonvillage is so quiet. It is a good time for me to study my ancient books. Lorilai thinks you can learn everything from a leaf. She is very wrong. $0",
  "venessa.dialogue.Sun21": "Sunday is a day for high spirits. I will spend my day cleaning my clinic. It must be perfect. Unlike Lorilai’s house... it smells like wet grass in there. $2",
  "venessa.dialogue.rain": "The rain cleans the air and the soul. I enjoy staying inside to polish my healing gems while the water falls. $1",
  "venessa.dialogue.GreenRain": "This green rain... it feels like ancient, wild magic. It is very strange. Annette told me Kira is hiding under the bed. Stay safe, @. $3",
  "venessa.dialogue.spring_Mon": "Spring has returned! The magic in the air is very strong. It makes my morning walks so refreshing. $1",
  "venessa.dialogue.summer_Wed": "The heat is intense. Drink plenty of water, @. I had to give Annette a cooling potion today because she was working too much. $0",
  "venessa.dialogue.fall_Fri": "The leaves are falling. It is a beautiful cycle of life. A good time to gather energy before the frost. $1",
  "venessa.dialogue.winter_Sun": "It is so cold. Please stay warm by your fire. I saw Kira wearing a tiny coat today... Annette cares for that dog very much. $3",
  "venessa.dialogue.Saloon": "It is quite loud in here, isn't it? I prefer the quiet hum of my healing crystals. I saw Lorilai earlier... she has dirt under her fingernails even at dinner. $2",
  "venessa.dialogue.Mountain": "The lake is beautiful, but the damp air is not good for my hair. I am only here because Annette said the fresh air would do me good. $0",
  "venessa.dialogue.Forest": "The forest is full of wild magic, but it is so unorganized. Lorilai loves it here, but I prefer a clean clinic where I can find my tools. $2",
  "venessa.dialogue.Hospital": "Welcome to my clinic. Please try not to bring any mud inside. I just finished cleaning the floors with a purifying spell. $1",
  "venessa.dialogue.Hearts_2": "It is nice to talk to you, @. I think we are becoming good friends. $1",
  "venessa.dialogue.Hearts_4": "You have a kind heart. Moonvillage feels more alive with you here. $1",
  "venessa.dialogue.Hearts_6": "I am glad you moved here. I usually prefer the company of trees, but I like talking to you. $1",
  "venessa.dialogue.Hearts_8": "I trust you, @. My elven heart feels very peaceful when you are nearby. $3",
  "venessa.dialogue.Hearts_10": "You are my favorite person in this valley. Thank you for being such a wonderful friend to me. $1",
  "venessa.dialogue.AcceptGift_Loved": "This is wonderful! It has such a pure energy. Thank you so much, @! $1",
  "venessa.dialogue.AcceptGift_Liked": "A gift? How thoughtful of you. I will cherish this. $1",
  "venessa.dialogue.AcceptGift_Neutral": "Thank you. This is a kind gesture. $1",
  "venessa.dialogue.AcceptGift_Disliked": "Oh... thank you, I suppose. But this does not fit my tastes. $2",
  "venessa.dialogue.AcceptGift_Hated": "This feels very wrong. Why would you give an Elf such a thing? $5",
  "venessa.dialogue.AcceptGift_(O)724": "Maple syrup! A sweet gift from the trees. This is lovely, thank you! $1",
  "venessa.dialogue.AcceptGift_(O)72": "A Diamond! It holds so much light and magic. Are you sure you want me to have this? $4",
  "venessa.dialogue.AcceptGift_(O)80": "Quartz. It is very useful for my healing work. I will use it well. $1",
  "venessa.dialogue.AcceptGift_(O)233": "Ice cream? It is very cold and sweet! A perfect treat for a busy Healer. $1",
  "venessa.dialogue.AcceptGift_(O)152": "Seaweed? It smells like salt and decay. I have no use for this. $3",
  "venessa.dialogue.AcceptGift_(O)167": "Joja Cola? Absolutely not. It is full of artificial chemicals. My body is a temple. $5",
  "venessa.dialogue.AcceptGift_(O)StardropTea": "Stardrop Tea... the most magical drink of all. You are too kind to me. $1",
  "venessa.dialogue.AcceptBirthdayGift_Loved": "You remembered my birthday? That makes me very happy, @. Thank you! $1",
  "venessa.dialogue.AcceptBirthdayGift_Liked": "A birthday present? You are very sweet to think of me. $1",
  "venessa.dialogue.FlowerDance_Accept": "I would love to dance with you. Let us show them the grace of an Elf. $1",
  "venessa.dialogue.FlowerDance_Decline": "I am sorry, @. I am feeling a bit too shy to dance today. $2",
  "venessa.dialogue.Dumped_Girls": "I thought we shared a special bond. It seems my heart was mistaken. $2",
  "venessa.dialogue.Divorce": "Please leave. I need to be alone with my magic and my thoughts. $5"
}